<!DOCTYPE html>
<html lang="en">
  <head>
    <base href="{{ '/' | url }}" target="_self">
    <title>{{ title | safe }}</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link href="https://fonts.googleapis.com/css?family=Nunito:300,400,700" rel="stylesheet">
    <link rel="stylesheet" href="{{ '/fonts/icomoon/style.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/bootstrap.min.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/jquery-ui.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/owl.carousel.min.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/owl.theme.default.min.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/jquery.fancybox.min.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/bootstrap-datepicker.css' | url }}">
    <link rel="stylesheet" href="{{ '/fonts/flaticon/font/flaticon.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/aos.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  </head>
  <body data-spy="scroll" data-target=".site-navbar-target" data-offset="300">

  <div id="overlayer"></div>
  <div class="loader">
    <div class="spinner-border text-primary" role="status">
      <span class="sr-only">Loading...</span>
    </div>
  </div>

  <div class="site-wrap" id="home-section">

    {% include "partials/header.njk" %}

    {{ content | safe }}

    {% include "partials/footer.njk" %}

  </div>

  <script src="{{ '/js/jquery-3.3.1.min.js' | url }}"></script>
  <script src="{{ '/js/jquery-ui.js' | url }}"></script>
  <script src="{{ '/js/popper.min.js' | url }}"></script>
  <script src="{{ '/js/bootstrap.min.js' | url }}"></script>
  <script src="{{ '/js/owl.carousel.min.js' | url }}"></script>
  <script src="{{ '/js/jquery.countdown.min.js' | url }}"></script>
  <script src="{{ '/js/bootstrap-datepicker.min.js' | url }}"></script>
  <script src="{{ '/js/jquery.easing.1.3.js' | url }}"></script>
  <script src="{{ '/js/aos.js' | url }}"></script>
  <script src="{{ '/js/jquery.fancybox.min.js' | url }}"></script>
  <script src="{{ '/js/jquery.sticky.js' | url }}"></script>
  <script src="{{ '/js/main.js' | url }}"></script>

  </body>
</html>
